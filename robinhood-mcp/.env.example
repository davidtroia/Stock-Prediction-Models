# ============================================================
# Robinhood credentials
# ============================================================
ROBINHOOD_USERNAME=your_email@example.com
ROBINHOOD_PASSWORD=your_password

# Optional: TOTP code for accounts with 2FA enabled
# Generate a fresh 6-digit code from your authenticator app right before
# starting the server — codes expire every 30 seconds.
ROBINHOOD_MFA_CODE=

# ============================================================
# Guardrails — trading safety limits
# All limits are enforced automatically before every order.
# Change these values and restart the server to update them.
# ============================================================

# Maximum % of total portfolio in any single stock (default: 10%)
MAX_POSITION_PCT=10

# Maximum dollar size of any single trade order (default: $1,000)
MAX_SINGLE_TRADE_USD=1000

# Always keep at least this % of total portfolio as cash (default: 10%)
MIN_CASH_RESERVE_PCT=10

# Halt all new buys if portfolio drops more than this % in one day (default: 3%)
DAILY_LOSS_LIMIT_PCT=3

# Maximum % of portfolio in any one sector (default: 30%)
MAX_SECTOR_PCT=30

# Trades above this dollar amount require explicit confirmation (default: $500)
REQUIRE_CONFIRMATION_ABOVE=500

# Whitelist: comma-separated list of the ONLY symbols allowed to trade.
# Leave empty to allow all symbols.
# Example: ALLOWED_SYMBOLS=AAPL,MSFT,NVDA,TSLA,SPY,QQQ
ALLOWED_SYMBOLS=

# Blacklist: comma-separated list of symbols to NEVER trade, regardless of anything else.
# Example: BLOCKED_SYMBOLS=GME,AMC,BBBY
BLOCKED_SYMBOLS=
